# ══════════════════════════════════════════════════════════════════
# MALE'DENIM OS — Variables de entorno
# Copia este archivo como .env y llena los valores reales.
# NUNCA subas .env a git.
# ══════════════════════════════════════════════════════════════════

# ── Melonn API (logística Colombia) ───────────────────────────────
MELONN_API_KEY=tu_x-api-key_del_seller_portal

# ── Shopify Admin API ──────────────────────────────────────────────
SHOPIFY_STORE=tu-tienda.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01
SHOPIFY_SYNC_INTERVALO_HORAS=2

# ── MercadoPago ────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase (caché + memoria operativa) ──────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOi...

# ══════════════════════════════════════════════════════════════════
# RAILWAY — bootstrap de Streamlit secrets desde env vars
# ══════════════════════════════════════════════════════════════════
# En local: usa .streamlit/secrets.toml (no necesitas la siguiente).
# En Railway: pega el contenido completo del .streamlit/secrets.toml
#             local aquí (multi-línea válida) para que bootstrap_secrets.py
#             lo regenere al arrancar.
#
# STREAMLIT_SECRETS_TOML='
# MELONN_API_KEY = "..."
# SHOPIFY_STORE = "..."
# ...
# [cookie]
# name = "maledenim_auth"
# key  = "..."
# expiry_days = 30
#
# [credentials.usernames.sebastian]
# name = "Sebastián Hurtado"
# email = "sebastian@example.com"
# password = "$2b$12$..."   # hash bcrypt
# role = "admin"
# permisos = ["logistica","comercial","mercadopago","conciliacion"]
# '
